# ---------------------------------------------------------------------------
# POUP — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha com suas credenciais reais.
# No Expo, apenas variáveis com o prefixo EXPO_PUBLIC_ ficam disponíveis
# no client (web/app). Segredos de servidor (service role, Stripe secret)
# NUNCA vão aqui — eles ficam nas Edge Functions do Supabase.
# ---------------------------------------------------------------------------

# Supabase (projeto POUP) — pegue em: Supabase Dashboard > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-public-key

# Stripe — chave publicável (pode ser exposta no client)
# Pegue em: Stripe Dashboard > Developers > API keys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs dos planos mensais (Stripe Dashboard > Products).
# Cada plano é um Produto com um preço recorrente mensal.
# Veja o passo a passo em docs/STRIPE_PLANOS.md
EXPO_PUBLIC_STRIPE_PRICE_START=price_...
EXPO_PUBLIC_STRIPE_PRICE_PRO=price_...

# URL base do app (usada para redirects de OAuth e Stripe Checkout).
# Local: http://localhost:8081  |  Produção: https://SEU-DOMINIO.vercel.app
EXPO_PUBLIC_APP_URL=http://localhost:8081
